from flask import Flask, request, jsonify\
import requests\
import os\
import json\
import re\
\
app = Flask(__name__)\
ANTHROPIC_KEY = os.environ.get('ANTHROPIC_KEY', '')\
\
@app.route('/suggest', methods=['POST'])\
def suggest():\
    try:\
        data = request.get_json()\
        inventory = data.get('inventory', [])\
        item_list = '\\n'.join([f"- \{item['name']\} (\{item['daysLeft']\} days left)" for item in inventory])\
        prompt = f"Here is my current fridge and pantry inventory with days until expiry:\\n\\n\{item_list\}\\n\\nSuggest exactly 3 recipes I could make that would best use the ingredients closest to expiring. For each recipe give me a name, a single short sentence explaining which expiring ingredients it uses, a difficulty level (Easy/Medium/Hard), and an estimated cook time. Respond ONLY with a JSON array in this exact format: [\{\{'name': 'Recipe Name', 'reason': 'Uses your chicken thighs', 'difficulty': 'Easy', 'time': '20 min'\}\}]"\
        response = requests.post('https://api.anthropic.com/v1/messages', headers=\{'Content-Type': 'application/json', 'x-api-key': ANTHROPIC_KEY, 'anthropic-version': '2023-06-01'\}, json=\{'model': 'claude-haiku-4-5-20251001', 'max_tokens': 1024, 'messages': [\{'role': 'user', 'content': prompt\}]\})\
        result = response.json()\
        text = result['content'][0]['text']\
        cleaned = text.replace('```json', '').replace('```', '').strip()\
        suggestions = json.loads(cleaned)\
        return jsonify(\{'suggestions': suggestions\})\
    except Exception as e:\
        return jsonify(\{'error': str(e)\}), 500\
\
@app.route('/parse-recipe', methods=['POST'])\
def parse_recipe():\
    try:\
        data = request.get_json()\
        raw_text = data.get('text', '')\
        prompt = f"""You are a recipe parser. Extract the recipe from the text below and return it as structured JSON.\
\
CRITICAL FORMATTING RULES for ingredients:\
- ingredient name: base ingredient ONLY, Title Case, singular form. NO prep methods, NO descriptors.\
  CORRECT: "Yellow Onion", "Cilantro", "Jalape\'f1o Pepper", "Chicken Thigh"\
  WRONG: "diced yellow onion", "fresh cilantro loosely packed", "minced jalape\'f1o", "boneless skinless chicken thighs"\
- prep: how to prepare it, lowercase. Examples: "diced", "minced", "loosely packed", "husks removed", "skin removed"\
- quantity: a number only. Normalize ranges to midpoint (6 to 8 = 7). Normalize "about 2" to 2. "half" = 0.5.\
- unit: one of: tsp, tbsp, cup, oz, lb, g, ml, l \'97 or null for countable items (onions, eggs, cloves)\
\
For steps: clean, numbered instructions. No prep notes that belong in ingredients.\
\
Return ONLY this JSON, no other text:\
\{\{\
  "name": "Recipe Name",\
  "time": "30 min",\
  "difficulty": "Easy",\
  "ingredients": [\
    \{\{"name": "Yellow Onion", "quantity": 2, "unit": null, "prep": "diced"\}\},\
    \{\{"name": "Olive Oil", "quantity": 2, "unit": "tbsp", "prep": null\}\},\
    \{\{"name": "Kosher Salt", "quantity": 1, "unit": "tsp", "prep": null\}\}\
  ],\
  "steps": [\
    "Heat oil in a large pan over medium heat.",\
    "Add onions and cook until softened, about 5 minutes."\
  ]\
\}\}\
\
Recipe text to parse:\
\{raw_text[:6000]\}"""\
\
        response = requests.post(\
            'https://api.anthropic.com/v1/messages',\
            headers=\{'Content-Type': 'application/json', 'x-api-key': ANTHROPIC_KEY, 'anthropic-version': '2023-06-01'\},\
            json=\{'model': 'claude-haiku-4-5-20251001', 'max_tokens': 2048, 'messages': [\{'role': 'user', 'content': prompt\}]\}\
        )\
        result = response.json()\
        text = result['content'][0]['text']\
        cleaned = text.replace('```json', '').replace('```', '').strip()\
        recipe = json.loads(cleaned)\
        return jsonify(\{'success': True, 'recipe': recipe\})\
    except Exception as e:\
        return jsonify(\{'success': False, 'error': str(e)\}), 500\
\
@app.route('/health', methods=['GET'])\
def health():\
    return jsonify(\{'status': 'ok'\})\
\
if __name__ == '__main__':\
    app.run(host='0.0.0.0', port=5002, debug=False)}